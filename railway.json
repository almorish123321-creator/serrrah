{
  "$schema": "https://railway.com/railway.schema.json",
  "services": {
    "bot": {
      "source": "bot",
      "build": {
        "builder": "nixpacks"
      },
      "deploy": {
        "startCommand": "python bot_updated.py",
        "numReplicas": 1,
        "restartPolicyType": "ON_FAILURE",
        "sleepApplication": false
      }
    },
"website": {
  "source": "website",
  "build": {
    "builder": "docker"
  },
  "deploy": {
    "numReplicas": 1
  }
} 
