{
  "$schema": "https://railway.com/railway.schema.json",
  "services": {
    "bot": {
      "source": "bot",
      "build": {
        "builder": "nixpacks",
        "buildEnvironment": "python3",
        "buildCommand": "pip install -r requirements.txt"
      },
      "deploy": {
        "startCommand": "python bot.py",
        "numReplicas": 1,
        "restartPolicyType": "ON_FAILURE",
        "sleepApplication": false
      }
    },
    "website": {
      "source": "website",
      "build": {
        "builder": "static",
        "publishDirectory": "."
      },
      "deploy": {
        "numReplicas": 1
      }
    }
  }
}
